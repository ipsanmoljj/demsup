# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb          # Commit .py versions via jupytext, not notebooks with outputs

# ── Large data — NEVER commit these ─────────────────────────────────────────
data/parquet/           # LFS-tracked or DVC-tracked (see .gitattributes / .dvc)
data/cache/             # Local speed cache — always regeneratable
data/raw/               # Original source files — store externally
*.parquet
*.h5
*.hdf5
*.feather
*.arrow

# ── Model artifacts ──────────────────────────────────────────────────────────
models/saved/
*.pkl
*.joblib
*.pt
*.onnx

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.*
config/secrets.yaml
config/local.yaml

# ── OS / editors ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Test and coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
